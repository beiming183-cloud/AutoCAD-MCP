<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net8.0-windows</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <PlatformTarget>x64</PlatformTarget>
    <RootNamespace>AutoCADMcp.Plugin</RootNamespace>
    <AssemblyName>AutoCADMcp.Plugin</AssemblyName>
    <AutoCADDir Condition="'$(AutoCADDir)' == ''">$(AUTOCAD_MCP_AUTOCAD_DIR)</AutoCADDir>
  </PropertyGroup>

  <ItemGroup>
    <Reference Include="AcCoreMgd">
      <HintPath>$(AutoCADDir)\AcCoreMgd.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="AcDbMgd">
      <HintPath>$(AutoCADDir)\AcDbMgd.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="AcMgd">
      <HintPath>$(AutoCADDir)\AcMgd.dll</HintPath>
      <Private>false</Private>
    </Reference>
  </ItemGroup>

  <Target Name="ValidateAutoCADReferences" BeforeTargets="ResolveReferences">
    <Error Condition="!Exists('$(AutoCADDir)\AcMgd.dll')"
           Text="Set AutoCADDir or AUTOCAD_MCP_AUTOCAD_DIR to the AutoCAD 2025/2026 install directory." />
  </Target>
</Project>
